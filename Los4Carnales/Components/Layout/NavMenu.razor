@implements IDisposable

@inject NavigationManager NavigationManager
@* Inyectamos SweetAlert para la alerta del PIN *@
@inject SweetAlertService Swal
@rendermode InteractiveServer

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid text-center" style="transform: translateX(-15px);">
        <a class="navbar-brand logo-centrado" href="/">
            <img src="Imagenes/Logo.png" alt="Logo" style="height: 140px; width: auto;" />
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">

        <AuthorizeView Roles="Administrador">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/Resumen" Match="NavLinkMatch.All">
                        <span class="bi bi-bar-chart-line" aria-hidden="true"></span> Resumen
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/Almacen" Match="NavLinkMatch.All">
                        <span class="bi bi-inbox-fill" aria-hidden="true"></span> Almacen
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/Facturacion/Index">
                        <span class="bi bi-cart3" aria-hidden="true"></span> Facturación
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/Transferencia/Index">
                        <span class="bi bi-credit-card" aria-hidden="true"></span> Transferencias
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/Admin/Mayoristas">
                        <span class="bi bi-buildings" aria-hidden="true"></span> Mayoristas
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/Logistica/Index">
                        <span class="bi bi-bezier2" aria-hidden="true"></span> Logistica
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/Proveedor/Index">
                        <span class='bi bi-truck' aria-hidden="true"></span> Proveedores
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        @* --- ZONA MASTER CON DOBLE SEGURIDAD --- *@
        <AuthorizeView Roles="Master">
            <Authorized>
                <div class="nav-item px-3">
                    @* Cambiamos el NavLink por un enlace clickeable que llama al método *@
                    <a class="nav-link text-warning fw-bold" style="cursor: pointer;" @onclick="VerificarPinMaster">
                        <span class="bi bi-shield-lock-fill" aria-hidden="true"></span> Papelera VIP
                    </a>
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Manage">
                        <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span> @context.User.Identity?.Name
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="Account/Login" />
                        <button type="submit" class="nav-link">
                            <span class="bi bi-arrow-bar-left-nav-menu" aria-hidden="true"></span> Logout
                        </button>
                    </form>
                </div>

            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Register">
                        <span class="bi bi-person-nav-menu" aria-hidden="true"></span> Sign in
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Login">
                        <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span> Login
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    // --- NUEVO MÉTODO DE SEGURIDAD PARA EL PIN ---
    private async Task VerificarPinMaster()
    {
        var result = await Swal.FireAsync(new SweetAlertOptions
        {
            Title = "Bóveda de Seguridad",
            Text = "Ingrese el PIN de Los 4 Carnales:",
            Input = SweetAlertInputType.Password,
            InputPlaceholder = "****",
            Icon = SweetAlertIcon.Info,
            ShowCancelButton = true,
            ConfirmButtonText = "<i class=\"bi bi-unlock-fill\"></i> Desbloquear",
            CancelButtonText = "Cancelar",
            ConfirmButtonColor = "#3D5D35",
            CancelButtonColor = "#6c757d"
        });

        // Verificamos si escribió algo y le dio a confirmar
        if (!string.IsNullOrEmpty(result.Value))
        {
            string pinIngresado = result.Value;

            // ESTE ES EL PIN SECRETO (Cámbialo por el que ustedes 4 decidan)
            if (pinIngresado == "2024")
            {
                // Si es correcto, lo mandamos al Resumen del Master (el que hicimos hoy)
                NavigationManager.NavigateTo("/Master/Resumen");
            }
            else
            {
                // Si falla, mostramos error
                await Swal.FireAsync(new SweetAlertOptions
                {
                    Title = "Acceso Denegado",
                    Text = "El PIN ingresado es incorrecto.",
                    Icon = SweetAlertIcon.Error,
                    ConfirmButtonColor = "#C15349"
                });
            }
        }
    }
}