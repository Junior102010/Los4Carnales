@rendermode InteractiveServer

<div class="sidebar-master">
    <div class="brand-logo">
        <img src="@rutaLogoActual"
             @onclick="CambiarLogo"
             alt="Logo"
             style="height: 140px; width: auto; cursor: pointer;" />
    </div>

    <nav class="nav-master">
        <NavLink class="nav-item-master" href="/Master/Resumen">
            <i class="bi bi-bar-chart-fill"></i> Resumen
        </NavLink>

        <NavLink class="nav-item-master" href="/Master/Almacen">
            <i class="bi bi-box-seam-fill"></i> Almacen
        </NavLink>

        <NavLink class="nav-item-master" href="/Master/Proveedores">
            <i class="bi bi-truck-front-fill"></i> Proveedores
        </NavLink>

        <NavLink class="nav-item-master" href="/Master/Usuarios">
            <i class="bi bi-people-fill"></i> Usuarios
        </NavLink>

        <NavLink class="nav-item-master" href="/Master/Facturacion">
            <i class="bi bi-cart-fill"></i> Facturacion
        </NavLink>

        <NavLink class="nav-item-master" href="/Master/Entradas">
            <i class="bi bi-box-arrow-in-down"></i> Entradas
        </NavLink>

        <NavLink class="nav-item-master" href="/Master/Logistica">
            <i class="bi bi-bezier2"></i> Logistica
        </NavLink>

        <div style="margin-top: auto; margin-bottom: 30px;">
            <form action="Account/Logout" method="post" class="w-100 m-0 p-0">
                <AntiforgeryToken />
                <input type="hidden" name="ReturnUrl" value="Account/Login" />

                <button type="submit" class="nav-item-master w-100 text-start border-0" style="background-color: transparent;">
                    <i class="bi bi-box-arrow-left"></i> Salir del Sistema
                </button>
            </form>
        </div>
    </nav>
</div>

@code {

    private string rutaLogoActual = "Imagenes/Logo1.png";


    private void CambiarLogo()
    {
        if (rutaLogoActual == "Imagenes/Logo1.png")
        {
            rutaLogoActual = "Imagenes/Logo2.png";
        }
        else
        {
            rutaLogoActual = "Imagenes/Logo1.png";
        }
    }
}