@page "/Entrada/Index"
@using Microsoft.AspNetCore.Authorization

@rendermode InteractiveServer
@inject EntradasServices entradaServices
@inject NavigationManager navigationManager
@inject PageTitleService PageTitleService

@attribute [Authorize(Roles = "Administrador")]

<PageTitle>Registro de Entradas</PageTitle>

<div class="container">

    <div class="card card-glass rounded-4 p-2">

        <div class="card-body">

            @* --- FILTROS --- *@
            <div class="row align-items-end mb-4">

                <div class="col-md-3">
                    <label class="form-label text-muted small fw-bold mb-1">Filtrar por</label>
                    <InputSelect class="form-select input-glass" @bind-Value="Filtro">
                        <option value="" selected disabled>Elija una opción</option>
                        <option value="Nombre">Nombre</option>
                        <option value="Categoria">Categoría</option>
                    </InputSelect>
                </div>

                <div class="col-md-4">
                    <label class="form-label text-muted small fw-bold mb-1">Búsqueda</label>
                    <div class="input-group">
                        <input class="form-control input-glass" @bind="ValorFiltro" placeholder="Buscar..." />
                        <button type="button" class="btn btn-outline-success bi bi-search" @onclick="Buscar"></button>
                        <button type="button" class="btn btn-outline-secondary bi bi-arrow-counterclockwise" @onclick="Restablecer"></button>
                    </div>
                </div>

                <div class="col-md-1"></div>

                <div class="col-md-4 text-end">
                    <div class="d-flex justify-content-end gap-2">

                        <a href="/Entrada/Create" class="btn btn-gradiente px-3">
                            <span class="bi bi-plus-square"></span> Crear
                        </a>
                    </div>
                </div>
            </div>

            @* --- TABLA --- *@
            <div class="table-responsive">
                <table class="table table-hover bg-transparent align-middle">
                    <thead class="text-black" style="background-color: rgba(0,0,0,0.03); border-bottom: 2px solid rgba(0,0,0,0.1);">
                        <tr>
                            <th class="py-3 ps-3">Fecha</th>
                            <th class="py-3">Concepto</th>
                            <th class="py-3">Proveedor</th>
                            <th class="py-3">Cant. Articulos</th>

                            <th class="py-3 text-center">Opciones</th>
                        </tr>
                    </thead>
                    <tbody style="background-color: transparent;">
                        @foreach (var entrada in ListaEntrada)
                        {
                            <tr style="border-bottom: 1px solid rgba(0,0,0,0.05);">
                                <td class="ps-3 fw-bold text-muted">@entrada.FechaEntrada</td>
                                <td>@entrada.Concepto</td>
                                <td>@entrada.Proveedor</td>
                                <td>
                                    
                                        @entrada.EntradaDetalles.Count();
                                  
                                </td>


                                <td class="text-center">
                                    <a href="/Entrada/Edit/@entrada.EntradaId" class="btn btn-sm btn-outline-success border-0 bi bi-pencil-square fs-5"></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* --- FOOTER --- *@
        <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between text-muted mt-2 pt-0 pb-3 px-4">
            <small class="fw-bold">Cantidad: @ListaEntrada.Count()</small>
            
        </div>
    </div>
</div>

@code {
    public List<Entrada> ListaEntrada { get; set; } = new List<Entrada>();

    public string Filtro { get; set; } = string.Empty;
    public string ValorFiltro { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        PageTitleService.SetTitle("Almacen");
        ListaEntrada = await entradaServices.Listar(p => p.EntradaId > 0);
    }

    private async Task Buscar()
    {
        if (!string.IsNullOrWhiteSpace(ValorFiltro))
        {
            if (Filtro == "Nombre")
            {
                ListaEntrada = await entradaServices.Listar(
                    p => p.Concepto != null && p.Concepto.ToLower().Contains(ValorFiltro.ToLower()));
            }
            // else if (Filtro == "Categoria")
            // {
            //     ListaProductos = await productosService.Listar(
            //         p => p.Categoria != null && p.Categoria.ToLower().Contains(ValorFiltro.ToLower()));
            // }
        }
        else
        {
            ListaEntrada = await entradaServices.Listar(p => p.EntradaId > 0);
        }
    }

    private async Task Restablecer()
    {
        ListaEntrada = await entradaServices.Listar(p => p.EntradaId > 0);
        Filtro = string.Empty;
        ValorFiltro = string.Empty;
    }
}