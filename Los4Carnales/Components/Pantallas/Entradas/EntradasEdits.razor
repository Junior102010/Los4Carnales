@page "/Entrada/Edit/{EntradaId:int}"

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Los4Carnales.Data

@rendermode InteractiveServer

@inject EntradasServices entradasService
@inject NavigationManager navigationManager
@inject PageTitleService PageTitleService
@inject SweetAlertService Swal
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

@attribute [Authorize(Roles = "Administrador")]

<PageTitle>Detalles de Entrada</PageTitle>

<div class="container">
    <div class="card card-glass rounded-4 p-2 mt-4">

        <EditForm Model="Entrada" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />

            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold text-muted m-0">Datos Generales (Editable)</h6>
                    <span class="badge bg-primary fs-6">Lote: @Entrada.NumeroLote</span>
                </div>

                <div class="row mb-4">
                    <div class="col-md-3">
                        <label class="form-label text-muted small fw-bold mb-1">Fecha</label>
                        <InputDate class="form-control input-glass" @bind-Value="Entrada.FechaEntrada" />
                        <ValidationMessage For="(() => Entrada.FechaEntrada)" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label text-muted small fw-bold mb-1">Proveedor</label>
                        <InputSelect class="form-select input-glass" @bind-Value="Entrada.ProveedorId">
                            <option value="0" disabled>Seleccione...</option>
                            @foreach (var prov in ListaProveedores)
                            {
                                <option value="@prov.ProveedorId">@prov.Nombre</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="(() => Entrada.ProveedorId)" />
                    </div>

                    <div class="col-md-5">
                        <label class="form-label text-muted small fw-bold mb-1">Referencia / Concepto</label>
                        <InputText class="form-control input-glass" @bind-Value="Entrada.Concepto" />
                        <ValidationMessage For="(() => Entrada.Concepto)" />
                    </div>
                </div>

                <hr class="border-secondary opacity-25" />

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold text-muted m-0">Productos Recibidos</h6>
                    <span class="badge bg-success bg-opacity-75">Solo Lectura</span>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover bg-transparent align-middle">
                        <thead class="text-black" style="background-color: rgba(0,0,0,0.03);">
                            <tr>
                                <th class="ps-3">Producto</th>
                                <th class="text-center">Categoría</th>
                                <th class="text-center">Unidad</th>
                                <th class="text-center">Cantidad Recibida</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Entrada.EntradaDetalles)
                            {
                                <tr style="border-bottom: 1px solid rgba(0,0,0,0.05);">
                                    <td class="ps-3">@(item.Producto?.NombreProducto ?? "Producto Eliminado")</td>
                                    <td class="text-center small text-muted">@(item.Producto?.Categoria.Nombre ?? "-")</td>
                                    <td class="text-center small text-muted">@(item.Producto?.UnidadMedida.Descripcion ?? "-")</td>
                                    <td class="text-center fw-bold fs-5" style="color: #3D5D35;">@item.Cantidad</td>
                                </tr>
                            }
                            @if (!Entrada.EntradaDetalles.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted">No hay detalles disponibles.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>

            <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between align-items-center mt-2 pt-0 pb-3 px-4">
                <a href="/Entrada/Index" class="btn btn-outline-secondary px-4">
                    <span class="bi bi-arrow-left"></span> Volver
                </a>

                <div class="d-flex gap-2">
                    @* Solo mostramos el botón eliminar si ya existe en BD *@
                    @if (Entrada.EntradaId > 0)
                    {
                        <button type="button" class="btn btn-outline-danger px-4" @onclick="Eliminar">
                            <span class="bi bi-trash"></span> Eliminar
                        </button>
                    }

                    <button type="submit" class="btn btn-gradiente px-5">
                        <span class="bi bi-floppy"></span> Guardar
                    </button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public int EntradaId { get; set; }

    [SupplyParameterFromForm]
    public Entrada Entrada { get; set; } = new Entrada();

    public List<Proveedores> ListaProveedores { get; set; } = new List<Proveedores>();

    protected override async Task OnInitializedAsync()
    {
        PageTitleService.SetTitle("Editar Entrada");
        ListaProveedores = await entradasService.ListarProveedores();

        if (EntradaId > 0)
        {
            var encontrada = await entradasService.Buscar(EntradaId);
            if (encontrada != null)
            {
                Entrada = encontrada;
            }
        }
    }

    public async Task Guardar()
    {
        try
        {
            var ok = await entradasService.Guardar(Entrada);

            if (ok)
            {
                await Swal.FireAsync(new SweetAlertOptions
                {
                    Title = "¡Guardado!",
                    Text = "La entrada se guardó exitosamente.",
                    Icon = SweetAlertIcon.Success
                });

                navigationManager.NavigateTo("/Entrada/Index");
            }
        }
        catch (Exception ex)
        {
            await Swal.FireAsync(new SweetAlertOptions
            {
                Title = "Error",
                Text = "Ocurrió un problema al guardar.",
                Icon = SweetAlertIcon.Error
            });
            Console.WriteLine(ex.Message);
        }
    }

    public async Task Eliminar()
    {
        var confirmacion = await Swal.FireAsync(new SweetAlertOptions
        {
            Title = "¿Estás seguro?",
            Text = $"¿Deseas eliminar la entrada {Entrada.NumeroLote} y restar su inventario?",
            Icon = SweetAlertIcon.Warning,
            ShowCancelButton = true,
            ConfirmButtonText = "<i class=\"bi bi-trash-fill me-1\"></i> Eliminar",
            CancelButtonText = "<i class=\"bi bi-x-circle-fill me-1\"></i> Cancelar"
        });

        if (!string.IsNullOrEmpty(confirmacion.Value))
        {
            var passwordResult = await Swal.FireAsync(new SweetAlertOptions
            {
                Title = "Confirmar identidad",
                Text = "Ingresa tu contraseña de administrador para autorizar:",
                Input = SweetAlertInputType.Password,
                InputPlaceholder = "Tu contraseña",
                ShowCancelButton = true,
                ConfirmButtonText = "<i class=\"bi bi-shield-lock-fill me-1\"></i> Verificar",
                CancelButtonText = "<i class=\"bi bi-x-circle-fill me-1\"></i> Cancelar"
            });

            if (!string.IsNullOrEmpty(passwordResult.Value))
            {
                string passwordIngresado = passwordResult.Value;
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var user = await UserManager.GetUserAsync(authState.User);

                bool passwordCorrecto = false;
                if (user != null)
                {
                    passwordCorrecto = await UserManager.CheckPasswordAsync(user, passwordIngresado);
                }

                if (passwordCorrecto)
                {
                    // Llama al servicio de Entradas para hacer el borrado lógico
                    var ok = await entradasService.Eliminar(Entrada.EntradaId);

                    if (ok)
                    {
                        await Swal.FireAsync(new SweetAlertOptions
                        {
                            Title = "¡Eliminado!",
                            Text = "La entrada se borró correctamente.",
                            Icon = SweetAlertIcon.Success
                        });
                        navigationManager.NavigateTo("/Entrada/Index");
                    }
                    else
                    {
                        await Swal.FireAsync(new SweetAlertOptions
                        {
                            Title = "Error",
                            Text = "No se pudo eliminar de la base de datos.",
                            Icon = SweetAlertIcon.Error
                        });
                    }
                }
                else
                {
                    await Swal.FireAsync(new SweetAlertOptions
                    {
                        Title = "Acceso Denegado",
                        Text = "La contraseña es incorrecta. Operación cancelada.",
                        Icon = SweetAlertIcon.Error
                    });
                }
            }
        }
    }
}