@page "/Producto/Create"
@using Microsoft.AspNetCore.Authorization
@using Los4Carnales.Services
@using Los4Carnales.Models

@inject ProductosServices productosService
@inject UnidadMedidaService unidadService
@inject CategoriaService categoriaService
@inject NavigationManager navigationManager
@inject PageTitleService PageTitleService

@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrador")]

<PageTitle>Crear Producto</PageTitle>

<EditForm Model="Producto" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />

    <div class="container">
        <div class="card card-glass rounded-4 p-2">

            <div class="card-body">

                <div class="row mb-4">
                    <div class="col-md-4">
                        <label class="form-label text-muted small fw-bold">Nombre del Producto</label>
                        <InputText class="form-control input-glass"
                                   @bind-Value="Producto.NombreProducto"
                                   @bind-Value:after="GenerarEtiqueta"
                                   placeholder="Ej: Pollo Entero" />
                        <ValidationMessage For="(() => Producto.NombreProducto)" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label text-muted small fw-bold">Categoría</label>
                        <div class="input-group">
                            <InputSelect class="form-select input-glass"
                                         @bind-Value="Producto.CategoriaId"
                                         @bind-Value:after="GenerarEtiqueta">
                                <option value="0" disabled>Seleccione una categoria...</option>
                                @foreach (var c in ListaCategorias)
                                {
                                    <option value="@c.CategoriaId">@c.Nombre</option>
                                }
                            </InputSelect>
                            <a href="/Logistica/Categorias" class="btn btn-outline-secondary">
                                <i class="bi bi-gear"></i>
                            </a>
                        </div>
                        <ValidationMessage For="(() => Producto.CategoriaId)" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label text-muted small fw-bold">Etiqueta</label>
                        <InputText class="form-control input-glass text-primary fw-bold"
                                   @bind-Value="Producto.Etiqueta"
                                   readonly />
                        <ValidationMessage For="(() => Producto.Etiqueta)" />
                    </div>
                </div>

                <hr />

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label text-muted small fw-bold">Costo</label>
                        <InputNumber class="form-control input-glass"
                                     @bind-Value="Producto.Costo" />
                        <ValidationMessage For="(() => Producto.Costo)" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label text-muted small fw-bold">Precio</label>
                        <InputNumber class="form-control input-glass"
                                     @bind-Value="Producto.Precio" />
                        <ValidationMessage For="(() => Producto.Precio)" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label text-muted small fw-bold">Precio Empresa</label>
                        <InputNumber class="form-control input-glass"
                                     @bind-Value="Producto.PrecioEmpresa" />
                        <ValidationMessage For="(() => Producto.PrecioEmpresa)" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-bold">Unidad</label>
                        <div class="input-group">
                            <InputSelect class="form-select input-glass"
                                         @bind-Value="Producto.UnidadMedidaId">
                                <option value="0" disabled>Seleccione unidad</option>
                                @foreach (var u in ListaUnidades)
                                {
                                    <option value="@u.UnidadId">
                                        @u.Descripcion (@u.Abreviatura)
                                    </option>
                                }
                            </InputSelect>
                            <a href="/Logistica/Unidades" class="btn btn-outline-secondary">
                                <i class="bi bi-gear"></i>
                            </a>
                        </div>
                        <ValidationMessage For="(() => Producto.UnidadMedidaId)" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-bold">Existencia</label>
                        <InputNumber class="form-control input-glass"
                                     @bind-Value="Producto.Existencia"
                                     disabled />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Mensaje))
                {
                    <div class="alert alert-danger text-center">
                        @Mensaje
                    </div>
                }
            </div>

            <div class="card-footer d-flex justify-content-between">
                <a href="/Almacen" class="btn btn-outline-secondary">Volver</a>
                <button type="submit" class="btn btn-primary">Guardar</button>
            </div>
        </div>
    </div>
</EditForm>

@code {
    public Producto Producto { get; set; } = new();
    public string Mensaje { get; set; } = string.Empty;

    public List<UnidadMedida> ListaUnidades { get; set; } = new();
    public List<Categorias> ListaCategorias { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        PageTitleService.SetTitle("Crear Producto");
        Producto.Existencia = 0;

        ListaUnidades = await unidadService.Listar(_ => true);
        ListaCategorias = await categoriaService.Listar(_ => true);
    }

    private void GenerarEtiqueta()
    {
        // Validamos que exista un ID seleccionado y un nombre escrito
        if (Producto.CategoriaId == 0 || string.IsNullOrWhiteSpace(Producto.NombreProducto))
            return;

        // Buscamos la categoría en nuestra lista usando el ID
        var catSeleccionada = ListaCategorias.FirstOrDefault(c => c.CategoriaId == Producto.CategoriaId);

        if (catSeleccionada != null && !string.IsNullOrWhiteSpace(catSeleccionada.Nombre))
        {
            string letraNombre = Producto.NombreProducto.Substring(0, 1).ToUpper();

            string letrasCat = catSeleccionada.Nombre.Length >= 2
                ? catSeleccionada.Nombre.Substring(0, 2).ToUpper()
                : catSeleccionada.Nombre.ToUpper();

            string numeracion = Random.Shared.Next(1, 10000).ToString("D4");

            Producto.Etiqueta = $"{letraNombre}{letrasCat}{numeracion}";
        }
    }

    public async Task Guardar()
    {
        Mensaje = string.Empty;

        if (Producto.CategoriaId == 0 || Producto.UnidadMedidaId == 0)
        {
            Mensaje = "Debe seleccionar una Categoría y una Unidad de Medida.";
            return;
        }

        if (Producto.Costo < 0 || Producto.Precio < 0 || Producto.PrecioEmpresa < 0)
        {
            Mensaje = "Los precios no pueden ser negativos.";
            return;
        }

        var guardado = await productosService.Guardar(Producto);

        if (guardado)
        {
            navigationManager.NavigateTo("/Almacen");
        }
        else
        {
            Mensaje = "Error al guardar el producto.";
        }
    }
}