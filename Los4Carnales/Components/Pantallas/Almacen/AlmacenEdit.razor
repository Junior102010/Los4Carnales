@page "/Producto/Edit/{ProductoId:int}"
@using Microsoft.AspNetCore.Authorization
@using Los4Carnales.Models
@using Los4Carnales.Services

@rendermode InteractiveServer

@inject ProductosServices productosService
@inject CategoriaService categoriaService
@inject UnidadMedidaService unidadService
@inject NavigationManager navigationManager
@inject PageTitleService PageTitleService

@attribute [Authorize(Roles = "Administrador")]

<PageTitle>Editar Producto</PageTitle>

<div class="container">
    <div class="card card-glass rounded-4 p-2">

        <EditForm Model="Producto" OnValidSubmit="Guardar" FormName="EditarProductoForm">
            <DataAnnotationsValidator />

            <div class="card-body">

                <div class="row mb-4">
                    <div class="col-md-4">
                        <label class="form-label text-muted small fw-bold mb-1">Nombre</label>
                        <InputText class="form-control input-glass" @bind-Value="Producto.NombreProducto" />
                        <ValidationMessage For="(() => Producto.NombreProducto)" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label text-muted small fw-bold mb-1">Categoría</label>
                        <div class="input-group">
                            <InputSelect class="form-select input-glass" @bind-Value="Producto.CategoriaId">
                                <option value="0" disabled>Seleccione...</option>
                                @foreach (var c in ListaCategorias)
                                {
                                    <option value="@c.CategoriaId">@c.Nombre</option>
                                }
                            </InputSelect>
                            <a href="/Logistica/Categorias" class="btn btn-outline-secondary">
                                <i class="bi bi-gear"></i>
                            </a>
                        </div>
                        <ValidationMessage For="(() => Producto.CategoriaId)" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label text-muted small fw-bold mb-1">Etiqueta</label>
                        <InputText class="form-control input-glass text-primary fw-bold"
                                   @bind-Value="Producto.Etiqueta"
                                   readonly />
                        <ValidationMessage For="(() => Producto.Etiqueta)" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label text-muted small fw-bold mb-1">Costo (Compra)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-end-0 text-muted">$</span>
                            <InputNumber class="form-control input-glass border-start-0" @bind-Value="Producto.Costo" />
                        </div>
                        <ValidationMessage For="(() => Producto.Costo)" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label text-muted small fw-bold mb-1">Precio (Venta Público)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-end-0 text-muted">$</span>
                            <InputNumber class="form-control input-glass border-start-0" @bind-Value="Producto.Precio" />
                        </div>
                        <ValidationMessage For="(() => Producto.Precio)" />
                    </div>

                    <div class="col-md-4 d-flex flex-column justify-content-end pb-2">
                        <span class="small text-muted">Margen estimado (Público):</span>
                        <h5 class="m-0 @(ObtenerColorGanancia())">
                            @((Producto.Precio - Producto.Costo).ToString("C2"))
                        </h5>
                    </div>
                </div>

                <hr class="border-secondary opacity-25" />

                <div class="row mb-3 align-items-end">

                    <div class="col-md-4">
                        <label class="form-label text-muted small fw-bold mb-1">Unidad de Medida</label>
                        <div class="input-group">
                            <InputSelect class="form-select input-glass" @bind-Value="Producto.UnidadMedidaId">
                                <option value="0" disabled>Seleccione...</option>
                                @foreach (var u in ListaUnidades)
                                {
                                    <option value="@u.UnidadId">@u.Descripcion (@u.Abreviatura)</option>
                                }
                            </InputSelect>
                            <a href="/Logistica/Unidades" class="btn btn-outline-secondary">
                                <i class="bi bi-gear"></i>
                            </a>
                        </div>
                        <ValidationMessage For="(() => Producto.UnidadMedidaId)" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label text-muted small fw-bold mb-1">Precio (Venta Empresa)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-end-0 text-muted">$</span>
                            <InputNumber class="form-control input-glass border-start-0" @bind-Value="Producto.PrecioEmpresa" />
                        </div>
                        <ValidationMessage For="(() => Producto.PrecioEmpresa)" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label text-muted small fw-bold mb-1">Existencia Actual</label>
                        @if (Producto.Existencia < 1)
                        {
                            <InputText class="form-control input-glass fw-bold" style="color: #3D5D35;" placeholder="Aún no existen entradas." @bind-Value="AvisoSinEntradas" disabled />
                        }
                        else
                        {
                            <InputNumber class="form-control input-glass fw-bold" style="color: #3D5D35;" @bind-Value="Producto.Existencia" />
                            <div class="form-text text-danger small fst-italic">
                                <i class="bi bi-exclamation-triangle"></i> Ajustar solo por daños o errores.
                            </div>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Mensaje))
                {
                    <div class="alert alert-danger mt-3 text-center py-2" role="alert">
                        <small>@Mensaje</small>
                    </div>
                }
            </div>

            <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between align-items-center mt-2 pt-0 pb-3 px-4">
                <a href="/Almacen" class="btn btn-outline-secondary px-4">
                    <span class="bi bi-arrow-left"></span> Volver
                </a>

                <button type="button" class="btn btn-danger" @onclick="Eliminar">
                    <span class="bi bi-trash"> </span> Eliminar
                </button>

                <button type="submit" class="btn btn-gradiente px-5">
                    <span class="bi bi-pencil-square"></span> Guardar Cambios
                </button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public int ProductoId { get; set; }

    [SupplyParameterFromForm]
    public Producto Producto { get; set; } = new Producto();

    public string Mensaje { get; set; } = string.Empty;
    public string AvisoSinEntradas { get; set; } = string.Empty;

    public List<Categorias> ListaCategorias { get; set; } = new();
    public List<UnidadMedida> ListaUnidades { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        PageTitleService.SetTitle("Editar Producto");

        ListaCategorias = await categoriaService.Listar(_ => true);
        ListaUnidades = await unidadService.Listar(_ => true);

        if (ProductoId > 0)
        {
            var encontrado = await productosService.Buscar(ProductoId);
            if (encontrado != null)
            {
                Producto = encontrado;
            }
            else
            {
                Mensaje = "El producto no fue encontrado.";
            }
        }
    }

    public async Task Eliminar()
    {
        var ok = await productosService.Eliminar(ProductoId);

        if (ok)
        {
            navigationManager.NavigateTo("/Almacen");
        }
    }

    public async Task Guardar()
    {
        Mensaje = string.Empty;

        if (Producto.CategoriaId <= 0 || Producto.UnidadMedidaId <= 0)
        {
            Mensaje = "Debe seleccionar una Categoría y una Unidad de Medida.";
            return;
        }

        if (Producto.Costo < 0 || Producto.Precio < 0 || Producto.PrecioEmpresa < 0)
        {
            Mensaje = "Los valores monetarios no pueden ser negativos.";
            return;
        }

        if (Producto.Existencia < 0)
        {
            Mensaje = "La existencia no puede ser negativa.";
            return;
        }

        var modificado = await productosService.Guardar(Producto);

        if (modificado)
        {
            navigationManager.NavigateTo("/Almacen");
        }
        else
        {
            Mensaje = "No se pudo actualizar el producto.";
        }
    }

    private string ObtenerColorGanancia()
    {
        if (Producto.Precio < Producto.Costo) return "text-danger";
        if (Producto.Precio == Producto.Costo) return "text-warning";
        return "text-success";
    }
}