@page "/Master/Facturacion"

@using Los4Carnales.Models
@using Los4Carnales.Services
@using Los4Carnales.Components.Layout

@layout MasterLayout

@rendermode InteractiveServer
@inject PageTitleService PageTitleService
@inject PedidosServices pedidosService
@inject NavigationManager navigationManager  
@inject IJSRuntime JS

@attribute [Authorize(Roles = "Master")]

<PageTitle>@PageTitleService.CurrentTitle</PageTitle>

<div class="top-header-master">
    @PageTitleService.CurrentTitle
</div>

<div class="content-body">
    <div class="controls-bar">
        <div class="d-flex gap-4">
            <div>
                <div class="filter-label">Filtrar por:</div>
                <select class="input-custom" @bind="CriterioFiltro">
                    <option value="Cliente">Cliente</option>
                    <option value="ID">ID Pedido</option>
                    <option value="MetodoPago">Método de Pago</option>
                </select>
            </div>

            <div>
                <div class="filter-label">Buscar</div>
                <div class="d-flex gap-1">
                    <input type="text" class="input-custom" placeholder="Escribe para buscar..."
                           @bind="TextoBusqueda" @bind:event="oninput" style="width: 250px;">
                    <button class="input-custom bg-white border"><i class="bi bi-search"></i></button>
                </div>
            </div>
        </div>

        <div class="badge-counter">
            <i class="bi bi-trash3-fill"></i>
            <div>
                <div class="fs-4 fw-bold lh-1 text-dark">@ListaFiltrada.Count</div>
                <small class="text-muted">Eliminados</small>
            </div>
        </div>
    </div>

    <div class="big-card-container">
        @* --- ENCABEZADOS DE LA TABLA --- *@
        <div class="table-header">
            <div style="width: 50px; text-align: center;">ID</div>
            <div style="width: 25%;">Cliente</div>
            <div style="width: 20%; text-align: left; padding-left: 15px;">Fecha</div>
            <div style="width: 15%; text-align: center;">Monto</div>
            <div style="width: 15%; text-align: center;">Estado</div>
            <div style="width: 150px; text-align: center;">Opciones</div>
        </div>

        @if (ListaPedidos.Count == 0)
        {
            <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted mt-5">
                <i class="bi bi-inbox fs-1 mb-3"></i>
                <h4>La papelera está vacía</h4>
                <p>No hay facturas eliminadas recientemente.</p>
            </div>
        }
        else
        {
            @foreach (var item in ListaFiltrada)
            {
                <div class="data-row">
                    @* ID Centrado *@
                    <div class="col-id" style="width: 50px; text-align: center;">@item.PedidoId</div>

                    @* Cliente Ajustado *@
                    <div class="col-name" style="width: 25%;">
                        <div class="fw-bold text-dark">
                            @(item.NombreCliente != string.Empty ? item.NombreCliente : "Desconocido")
                        </div>
                        <small class="text-muted"><i class="bi bi-wallet2"></i> Pago: @item.MetodoPago</small>
                    </div>

                    @* Fecha movida a la izquierda *@
                    <div style="width: 20%; text-align: left; padding-left: 15px;">
                        <span class="badge bg-light text-secondary border">@item.FechaPedido.ToString("dd/MM/yyyy")</span>
                    </div>

                    @* Monto Centrado *@
                    <div style="width: 15%; text-align: center;">
                        <span class="fw-bold" style="color: #3D5D35;">@item.MontoTotal.ToString("C2")</span>
                    </div>

                    @* Estado Centrado *@
                    <div class="col-status" style="width: 15%;">
                        X Eliminado
                    </div>

                    @* Opciones Centradas *@
                    <div class="col-actions" style="width: 150px;">
                        <button class="action-btn btn-view" title="Ver toda la información"
                                @onclick="() => MostrarDetalles(item)">
                            <i class="bi bi-eye-fill"></i>
                        </button>

                        <button class="action-btn btn-restore" title="Restaurar al sistema"
                                @onclick="() => Restaurar(item.PedidoId)">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </button>

                        <button class="action-btn btn-delete" title="Eliminar definitivamente"
                                @onclick="() => EliminarDefinitivamente(item.PedidoId)">
                            <i class="bi bi-trash3-fill"></i>
                        </button>
                    </div>
                </div>
            }
        }
    </div>
</div>

@* --- MODAL DE DETALLES --- *@
@if (ModalVisible && PedidoSeleccionado != null)
{
    <div class="custom-modal-backdrop" @onclick="CerrarModal">
        <div class="custom-modal-content" @onclick:stopPropagation="true">

            <div class="modal-header-custom">
                <h5 class="m-0 fw-bold text-dark"><i class="bi bi-receipt me-2"></i> Detalles de la Factura</h5>
                <button class="action-btn text-muted" @onclick="CerrarModal"><i class="bi bi-x-lg"></i></button>
            </div>

            <div class="modal-body-custom mt-3">
                <div class="row mb-3">
                    <div class="col-6">
                        <small class="text-muted fw-bold">ID Factura</small>
                        <p class="fs-5 mb-0 fw-bold text-dark">#@PedidoSeleccionado.PedidoId</p>
                    </div>
                    <div class="col-6 text-end">
                        <small class="text-muted fw-bold">Estado del Sistema</small>
                        <p class="mb-0 text-danger fw-bold">Eliminado</p>
                    </div>
                </div>

                <hr class="opacity-25" />

                <div class="row mb-3">
                    <div class="col-12 mb-2">
                        <small class="text-muted fw-bold">Cliente</small>
                        <p class="mb-0 text-dark fw-bold">
                            @(PedidoSeleccionado.NombreCliente != string.Empty ? PedidoSeleccionado.NombreCliente : "Desconocido")
                        </p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted fw-bold">Fecha de Emisión</small>
                        <p class="mb-0 text-dark">@PedidoSeleccionado.FechaPedido.ToString("dd/MM/yyyy hh:mm tt")</p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted fw-bold">Tipo de Entrega</small>
                        @if (PedidoSeleccionado.Delivery)
                        {
                            <p class="mb-0 text-info fw-bold"><i class="bi bi-bicycle"></i> Delivery</p>
                        }
                        else
                        {
                            <p class="mb-0 text-secondary fw-bold"><i class="bi bi-shop"></i> Local</p>
                        }
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-6">
                        <small class="text-muted fw-bold">Método de Pago</small>
                        <p class="mb-0 text-dark">@PedidoSeleccionado.MetodoPago</p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted fw-bold">Referencia / Dirección</small>
                        <p class="mb-0 text-dark">@(string.IsNullOrEmpty(PedidoSeleccionado.ReferenciaSitio) ? "N/A" : PedidoSeleccionado.ReferenciaSitio)</p>
                    </div>
                </div>

                <hr class="opacity-25" />

                <div class="row mb-3">
                    <div class="col-12 text-end">
                        <small class="text-muted fw-bold">Total Facturado</small>
                        <p class="fs-4 mb-0" style="color: #3D5D35; font-weight: bold;">@PedidoSeleccionado.MontoTotal.ToString("C2")</p>
                    </div>
                </div>
            </div>

            <div class="modal-footer-custom mt-4 text-end">
                <button class="btn btn-secondary px-4 rounded-pill" @onclick="CerrarModal">Cerrar</button>
            </div>
        </div>
    </div>
}

@code {
    public List<Pedido> ListaPedidos { get; set; } = new List<Pedido>();

    public string TextoBusqueda { get; set; } = "";
    public string CriterioFiltro { get; set; } = "Cliente";

    // Variables para el Modal
    public bool ModalVisible { get; set; } = false;
    public Pedido? PedidoSeleccionado { get; set; }

    public List<Pedido> ListaFiltrada
    {
        get
        {
            if (string.IsNullOrWhiteSpace(TextoBusqueda))
                return ListaPedidos;

            switch (CriterioFiltro)
            {
                case "ID":
                    return ListaPedidos.Where(p => p.PedidoId.ToString().Contains(TextoBusqueda)).ToList();
                case "MetodoPago":
                    return ListaPedidos.Where(p => p.MetodoPago != null && p.MetodoPago.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase)).ToList();
                case "Cliente":
                default:
                    return ListaPedidos.Where(p => p.NombreCliente != string.Empty &&
                        (p.NombreCliente.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase))).ToList();
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        PageTitleService.SetTitle("Facturacion Papeleria");
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        ListaPedidos = await pedidosService.ListarPapelera();
    }

    // Funciones del Modal
    private void MostrarDetalles(Pedido pedido)
    {
        PedidoSeleccionado = pedido;
        ModalVisible = true;
    }

    private void CerrarModal()
    {
        ModalVisible = false;
        PedidoSeleccionado = null;
    }

    private async Task Restaurar(int id)
    {
        var exito = await pedidosService.Restaurar(id);
        if (exito) await CargarDatos();
    }

    private async Task EliminarDefinitivamente(int id)
    {
        bool confirmar = await JS.InvokeAsync<bool>("confirm", "⚠️ ¿Estás seguro de eliminar este pedido PERMANENTEMENTE? Esta acción no se puede deshacer.");

        if (confirmar)
        {
            var exito = await pedidosService.EliminarPermanente(id);
            if (exito) await CargarDatos();
        }
    }
}