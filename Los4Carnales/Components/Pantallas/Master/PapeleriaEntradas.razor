@page "/Master/Entradas"

@using Los4Carnales.Models
@using Los4Carnales.Services
@using Los4Carnales.Components.Layout
@using Microsoft.AspNetCore.Authorization

@layout MasterLayout

@rendermode InteractiveServer
@inject EntradasServices entradasService
@inject NavigationManager navigationManager
@inject PageTitleService PageTitleService
@inject IJSRuntime JS

@attribute [Authorize(Roles = "Master")]

<PageTitle>@PageTitleService.CurrentTitle</PageTitle>

<div class="top-header-master text-center">
    @PageTitleService.CurrentTitle
</div>

<div class="content-body">
    <div class="controls-bar">
        <div class="d-flex gap-4">
            <div>
                <div class="filter-label">Filtrar por:</div>
                <select class="input-custom" @bind="CriterioFiltro">
                    <option value="Lote">Nº Lote</option>
                    <option value="Proveedor">Proveedor</option>
                    <option value="Concepto">Concepto / Factura</option>
                </select>
            </div>

            <div>
                <div class="filter-label">Buscar</div>
                <div class="d-flex gap-1">
                    <input type="text" class="input-custom" placeholder="Escribe para buscar..."
                           @bind="TextoBusqueda" @bind:event="oninput" style="width: 250px;">
                    <button class="input-custom bg-white border"><i class="bi bi-search"></i></button>
                </div>
            </div>
        </div>

        <div class="badge-counter">
            <i class="bi bi-trash3-fill"></i>
            <div>
                <div class="fs-4 fw-bold lh-1 text-dark">@ListaFiltrada.Count</div>
                <small class="text-muted">Eliminadas</small>
            </div>
        </div>
    </div>

    <div class="big-card-container">
        @* --- ENCABEZADOS AJUSTADOS --- *@
        <div class="table-header">
            <div style="width: 50px; text-align: center;">ID</div>
            <div style="width: 20%;">Nº Lote</div>
            <div style="width: 25%; text-align: left; padding-left: 15px;">Proveedor</div>
            <div style="width: 20%; text-align: left;">Concepto</div>
            <div style="width: 10%; text-align: center;">Total Items</div>
            <div style="width: 150px; text-align: center;">Opciones</div>
        </div>

        @if (ListaEntradas.Count == 0)
        {
            <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted mt-5">
                <i class="bi bi-inbox fs-1 mb-3"></i>
                <h4>La papelera está vacía</h4>
                <p>No hay entradas eliminadas recientemente.</p>
            </div>
        }
        else
        {
            @foreach (var item in ListaFiltrada)
            {
                <div class="data-row">
                    @* ID Centrado (Se mantiene pequeño para los Master, aunque en el Index normal no se vea) *@
                    <div class="col-id" style="width: 50px; text-align: center;">@item.EntradaId</div>

                    @* Lote y Fecha *@
                    <div class="col-name" style="width: 20%;">
                        <div class="fw-bold text-primary">@item.NumeroLote</div>
                        <small class="text-muted"><i class="bi bi-calendar-event"></i> @item.FechaEntrada.ToShortDateString()</small>
                    </div>

                    @* Proveedor *@
                    <div style="width: 25%; text-align: left; padding-left: 15px;">
                        <span class="badge bg-light text-secondary border">
                            <i class="bi bi-truck"></i> @(item.Proveedor?.Nombre ?? "Desconocido")
                        </span>
                    </div>

                    @* Concepto *@
                    <div style="width: 20%; text-align: left;">
                        <span class="fw-bold text-dark" style="font-size: 0.9rem;">@item.Concepto</span>
                    </div>

                    @* Cantidad de Items *@
                    <div style="width: 10%; text-align: center;">
                        <span class="fw-bold" style="color: #3D5D35; font-size: 1.1rem;">
                            @item.EntradaDetalles.Sum(d => d.Cantidad)
                        </span>
                    </div>

                    @* Opciones Centradas *@
                    <div class="col-actions" style="width: 150px;">
                        <button class="action-btn btn-view" title="Ver detalle de productos"
                                @onclick="() => MostrarDetalles(item)">
                            <i class="bi bi-eye-fill"></i>
                        </button>

                        <button class="action-btn btn-restore" title="Restaurar y devolver inventario"
                                @onclick="() => Restaurar(item.EntradaId)">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </button>

                        <button class="action-btn btn-delete" title="Eliminar definitivamente"
                                @onclick="() => EliminarDefinitivamente(item.EntradaId)">
                            <i class="bi bi-trash3-fill"></i>
                        </button>
                    </div>
                </div>
            }
        }
    </div>
</div>

@* --- MODAL DE DETALLES --- *@
@if (ModalVisible && EntradaSeleccionada != null)
{
    <div class="custom-modal-backdrop" @onclick="CerrarModal">
        <div class="custom-modal-content" style="width: 600px;" @onclick:stopPropagation="true">

            <div class="modal-header-custom">
                <h5 class="m-0 fw-bold text-dark"><i class="bi bi-box-arrow-in-down me-2"></i> Detalles de la Entrada</h5>
                <button class="action-btn text-muted" @onclick="CerrarModal"><i class="bi bi-x-lg"></i></button>
            </div>

            <div class="modal-body-custom mt-3">
                <div class="row mb-3 bg-light bg-opacity-50 p-2 rounded-3 border">
                    <div class="col-6">
                        <small class="text-muted fw-bold text-uppercase">Nº Lote</small>
                        <p class="fs-5 mb-0 fw-bold text-primary">@EntradaSeleccionada.NumeroLote</p>
                    </div>
                    <div class="col-6 text-end">
                        <small class="text-muted fw-bold text-uppercase">Estado actual</small>
                        <p class="mb-0 text-danger fw-bold"><i class="bi bi-trash3-fill"></i> Eliminada</p>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-12 mb-2">
                        <small class="text-muted fw-bold">Proveedor</small>
                        <p class="mb-0 text-dark fw-bold">
                            @(EntradaSeleccionada.Proveedor != null ? EntradaSeleccionada.Proveedor.Nombre : "Desconocido")
                        </p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted fw-bold">Fecha de Registro</small>
                        <p class="mb-0 text-dark">@EntradaSeleccionada.FechaEntrada.ToString("dd/MM/yyyy hh:mm tt")</p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted fw-bold">Referencia / Concepto</small>
                        <p class="mb-0 text-dark">@EntradaSeleccionada.Concepto</p>
                    </div>
                </div>

                <hr class="opacity-25" />
                <h6 class="fw-bold text-muted mb-2">Productos en esta Entrada:</h6>

                <div class="table-responsive" style="max-height: 200px; overflow-y: auto;">
                    <table class="table table-sm table-hover align-middle">
                        <thead class="text-muted" style="background-color: rgba(0,0,0,0.03);">
                            <tr>
                                <th>Producto</th>
                                <th class="text-center">Cant. Original</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detalle in EntradaSeleccionada.EntradaDetalles)
                            {
                                <tr>
                                    <td class="fw-bold text-dark">@(detalle.Producto?.NombreProducto ?? "Producto eliminado de BD")</td>
                                    <td class="text-center fw-bold" style="color: #3D5D35;">@detalle.Cantidad</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="row mt-2">
                    <div class="col-12 text-end">
                        <small class="text-muted fw-bold">Total Artículos Restados del Inventario:</small>
                        <p class="fs-5 mb-0 fw-bold text-danger">- @EntradaSeleccionada.EntradaDetalles.Sum(d => d.Cantidad)</p>
                    </div>
                </div>
            </div>

            <div class="modal-footer-custom mt-4 text-end">
                <button class="btn btn-secondary px-4 rounded-pill" @onclick="CerrarModal">Cerrar</button>
            </div>
        </div>
    </div>
}

@code {
    public List<Entrada> ListaEntradas { get; set; } = new List<Entrada>();

    public string TextoBusqueda { get; set; } = "";
    public string CriterioFiltro { get; set; } = "Lote";

    public bool ModalVisible { get; set; } = false;
    public Entrada? EntradaSeleccionada { get; set; }

    public List<Entrada> ListaFiltrada
    {
        get
        {
            if (string.IsNullOrWhiteSpace(TextoBusqueda))
                return ListaEntradas;

            switch (CriterioFiltro)
            {
                case "Proveedor":
                    return ListaEntradas.Where(e => e.Proveedor != null && e.Proveedor.Nombre.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase)).ToList();
                case "Concepto":
                    return ListaEntradas.Where(e => e.Concepto != null && e.Concepto.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase)).ToList();
                case "Lote":
                default:
                    return ListaEntradas.Where(e => e.NumeroLote != null && e.NumeroLote.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase)).ToList();
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        PageTitleService.SetTitle("Papelería de Entradas");
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        ListaEntradas = await entradasService.ListarPapelera();
    }

    private void MostrarDetalles(Entrada entrada)
    {
        EntradaSeleccionada = entrada;
        ModalVisible = true;
    }

    private void CerrarModal()
    {
        ModalVisible = false;
        EntradaSeleccionada = null;
    }

    private async Task Restaurar(int id)
    {
        bool confirmar = await JS.InvokeAsync<bool>("confirm", "⚠️ Al restaurar esta Entrada, los productos se volverán a SUMAR al inventario. ¿Deseas continuar?");
        if (confirmar)
        {
            var exito = await entradasService.Restaurar(id);
            if (exito) await CargarDatos();
        }
    }

    private async Task EliminarDefinitivamente(int id)
    {
        bool confirmar = await JS.InvokeAsync<bool>("confirm", "⚠️ ¿Estás seguro de eliminar esta Entrada PERMANENTEMENTE? Ya los productos fueron restados del inventario, esta acción solo limpiará el registro de la base de datos.");

        if (confirmar)
        {
            var exito = await entradasService.EliminarPermanente(id);
            if (exito) await CargarDatos();
        }
    }
}