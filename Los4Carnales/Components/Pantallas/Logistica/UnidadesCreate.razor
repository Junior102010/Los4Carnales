@page "/Logistica/Unidades/Create"
@page "/Logistica/Unidades/Edit/{UnidadId:int}"

@using Los4Carnales.Services
@using Los4Carnales.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Los4Carnales.Data

@inject UnidadMedidaService unidadService
@inject NavigationManager navigationManager
@inject PageTitleService PageTitleService
@inject SweetAlertService Swal
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrador")]

<PageTitle>@(UnidadId > 0 ? "Editar" : "Crear") Unidad</PageTitle>

<div class="container">
    <div class="card card-glass rounded-4 p-2 shadow-sm mx-auto" style="max-width: 500px;">

        <div class="card-header bg-transparent border-0 text-center pb-0">
            <h4 class="fw-bold text-primary">
                <i class="bi @(UnidadId > 0 ? "bi-pencil-square" : "bi-plus-circle")"></i>
                @(UnidadId > 0 ? "Editar Unidad" : "Nueva Unidad")
            </h4>
        </div>

        <EditForm Model="Unidad" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />

            <div class="card-body">

                <div class="mb-4">
                    <label class="form-label text-muted fw-bold small">DESCRIPCIÓN</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-primary">
                            <i class="bi bi-tag"></i>
                        </span>
                        <InputText class="form-control input-glass border-start-0"
                                   @bind-Value="Unidad.Descripcion"
                                   placeholder="Ej: Libra, Caja, Saco..." />
                    </div>
                    <ValidationMessage For="() => Unidad.Descripcion" />
                </div>

                <div class="mb-4">
                    <label class="form-label text-muted fw-bold small">ABREVIATURA</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-primary">
                            <i class="bi bi-fonts"></i>
                        </span>
                        <InputText class="form-control input-glass border-start-0"
                                   @bind-Value="Unidad.Abreviatura"
                                   placeholder="Ej: LB, CJ, UNID..." />
                    </div>
                    <ValidationMessage For="() => Unidad.Abreviatura" />
                    <small class="text-muted">Se mostrará en la tienda y facturas.</small>
                </div>

            </div>

            <div class="card-footer bg-transparent border-0 d-flex justify-content-between pb-3 px-4">

                <a href="/Logistica/Unidades" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>

                <div class="d-flex gap-2">

                    @* Botón eliminar SOLO en modo edición *@
                    @if (UnidadId > 0)
                    {
                        <button type="button" class="btn btn-outline-danger"
                                @onclick="Eliminar">
                            <i class="bi bi-trash"></i>
                        </button>
                    }

                    <button type="submit" class="btn btn-gradiente px-5 shadow-sm">
                        <i class="bi bi-check-circle-fill me-2"></i> Guardar
                    </button>

                </div>
            </div>

        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public int UnidadId { get; set; }

    public UnidadMedida Unidad { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        PageTitleService.SetTitle(UnidadId > 0 ? "Editar Unidad" : "Crear Unidad");

        if (UnidadId > 0)
        {
            var encontrada = await unidadService.Buscar(UnidadId);

            if (encontrada != null)
            {
                Unidad = encontrada;
            }
            else
            {
                navigationManager.NavigateTo("/Logistica/Unidades");
            }
        }
    }

    public async Task Guardar()
    {
        try
        {
            var guardado = await unidadService.Guardar(Unidad);

            if (guardado)
            {
                await Swal.FireAsync(new SweetAlertOptions
                {
                    Title = "¡Guardado!",
                    Text = "La unidad se guardó exitosamente.",
                    Icon = SweetAlertIcon.Success
                });

                navigationManager.NavigateTo("/Logistica/Unidades");
            }
        }
        catch (Exception ex)
        {
            await Swal.FireAsync(new SweetAlertOptions
            {
                Title = "Error",
                Text = "Ocurrió un problema al guardar.",
                Icon = SweetAlertIcon.Error
            });
            Console.WriteLine(ex.Message);
        }
    }

    public async Task Eliminar()
    {
        // 1. Alerta de Advertencia Inicial
        var confirmacion = await Swal.FireAsync(new SweetAlertOptions
        {
            Title = "¿Estás seguro?",
            Text = $"¿Deseas eliminar la unidad {Unidad.Descripcion}?",
            Icon = SweetAlertIcon.Warning,
            ShowCancelButton = true,
            ConfirmButtonText = "<i class=\"bi bi-trash-fill me-1\"></i> Eliminar",
            CancelButtonText = "<i class=\"bi bi-x-circle-fill me-1\"></i> Cancelar"
        });

        if (!string.IsNullOrEmpty(confirmacion.Value))
        {
            // 2. Pedimos la contraseña
            var passwordResult = await Swal.FireAsync(new SweetAlertOptions
            {
                Title = "Confirmar identidad",
                Text = "Ingresa tu contraseña de administrador para autorizar:",
                Input = SweetAlertInputType.Password,
                InputPlaceholder = "Tu contraseña",
                ShowCancelButton = true,
                ConfirmButtonText = "<i class=\"bi bi-shield-lock-fill me-1\"></i> Verificar",
                CancelButtonText = "<i class=\"bi bi-x-circle-fill me-1\"></i> Cancelar"
            });

            if (!string.IsNullOrEmpty(passwordResult.Value))
            {
                string passwordIngresado = passwordResult.Value;

                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var user = await UserManager.GetUserAsync(authState.User);

                bool passwordCorrecto = false;
                if (user != null)
                {
                    // Validación real con Identity
                    passwordCorrecto = await UserManager.CheckPasswordAsync(user, passwordIngresado);
                }

                if (passwordCorrecto)
                {
                    var ok = await unidadService.Eliminar(UnidadId);

                    if (ok)
                    {
                        await Swal.FireAsync(new SweetAlertOptions
                        {
                            Title = "¡Eliminado!",
                            Text = "La unidad se borró correctamente.",
                            Icon = SweetAlertIcon.Success
                        });
                        navigationManager.NavigateTo("/Logistica/Unidades");
                    }
                    else
                    {
                        await Swal.FireAsync(new SweetAlertOptions
                        {
                            Title = "Error",
                            Text = "No se pudo eliminar de la base de datos.",
                            Icon = SweetAlertIcon.Error
                        });
                    }
                }
                else
                {
                    await Swal.FireAsync(new SweetAlertOptions
                    {
                        Title = "Acceso Denegado",
                        Text = "La contraseña es incorrecta. Operación cancelada.",
                        Icon = SweetAlertIcon.Error
                    });
                }
            }
        }
    }
}