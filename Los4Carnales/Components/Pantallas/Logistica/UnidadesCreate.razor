@page "/Logistica/Unidades/Create"
@page "/Logistica/Unidades/Edit/{UnidadId:int}"

@using Los4Carnales.Services
@using Los4Carnales.Models
@using Microsoft.AspNetCore.Authorization

@inject UnidadMedidaService unidadService
@inject NavigationManager navigationManager
@inject PageTitleService PageTitleService

@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrador")]

<PageTitle>@(UnidadId > 0 ? "Editar" : "Crear") Unidad</PageTitle>

<div class="container">
    <div class="card card-glass rounded-4 p-2 shadow-sm mx-auto" style="max-width: 500px;">

        <div class="card-header bg-transparent border-0 text-center pb-0">
            <h4 class="fw-bold text-primary">
                <i class="bi @(UnidadId > 0 ? "bi-pencil-square" : "bi-plus-circle")"></i>
                @(UnidadId > 0 ? "Editar Unidad" : "Nueva Unidad")
            </h4>
        </div>

        <EditForm Model="Unidad" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />

            <div class="card-body">

                <div class="mb-4">
                    <label class="form-label text-muted fw-bold small">DESCRIPCIÓN</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-primary">
                            <i class="bi bi-tag"></i>
                        </span>
                        <InputText class="form-control input-glass border-start-0"
                                   @bind-Value="Unidad.Descripcion"
                                   placeholder="Ej: Libra, Caja, Saco..." />
                    </div>
                    <ValidationMessage For="() => Unidad.Descripcion" />
                </div>

                <div class="mb-4">
                    <label class="form-label text-muted fw-bold small">ABREVIATURA</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-primary">
                            <i class="bi bi-fonts"></i>
                        </span>
                        <InputText class="form-control input-glass border-start-0"
                                   @bind-Value="Unidad.Abreviatura"
                                   placeholder="Ej: LB, CJ, UNID..." />
                    </div>
                    <ValidationMessage For="() => Unidad.Abreviatura" />
                    <small class="text-muted">Se mostrará en la tienda y facturas.</small>
                </div>

            </div>

            <div class="card-footer bg-transparent border-0 d-flex justify-content-between pb-3 px-4">

                <a href="/Logistica/Unidades" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>

                <div class="d-flex gap-2">

                    @* Botón eliminar SOLO en modo edición *@
                    @if (UnidadId > 0)
                    {
                        <button type="button" class="btn btn-outline-danger"
                                @onclick="Eliminar">
                            <i class="bi bi-trash"></i>
                        </button>
                    }

                    <button type="submit" class="btn btn-gradiente px-5 shadow-sm">
                        <i class="bi bi-check-circle-fill me-2"></i> Guardar
                    </button>

                </div>
            </div>

        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public int UnidadId { get; set; }

    public UnidadMedida Unidad { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        PageTitleService.SetTitle(UnidadId > 0 ? "Editar Unidad" : "Crear Unidad");

        if (UnidadId > 0)
        {
            var encontrada = await unidadService.Buscar(UnidadId);

            if (encontrada != null)
            {
                Unidad = encontrada;
            }
            else
            {
                navigationManager.NavigateTo("/Logistica/Unidades");
            }
        }
    }

    public async Task Guardar()
    {
        var guardado = await unidadService.Guardar(Unidad);

        if (guardado)
        {
            navigationManager.NavigateTo("/Logistica/Unidades");
        }
    }

    public async Task Eliminar()
    {
        var eliminado = await unidadService.Eliminar(UnidadId);

        if (eliminado)
        {
            navigationManager.NavigateTo("/Logistica/Unidades");
        }
    }
}