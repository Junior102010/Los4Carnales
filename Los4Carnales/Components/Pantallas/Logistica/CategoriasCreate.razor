@page "/Logistica/Categorias/Create"
@page "/Logistica/Categorias/Edit/{CategoriaId:int}"

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Los4Carnales.Data
@using Los4Carnales.Services
@using Los4Carnales.Models

@inject CategoriaService categoriaService
@inject NavigationManager navigationManager
@inject PageTitleService PageTitleService
@inject SweetAlertService Swal
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrador")]

<PageTitle>@(CategoriaId > 0 ? "Editar" : "Crear") Categoría</PageTitle>

<div class="container">
    <div class="card card-glass rounded-4 p-2 shadow-sm mx-auto" style="max-width: 500px;">

        <div class="card-header bg-transparent border-0 text-center pb-0">
            <h4 class="fw-bold text-warning">
                <i class="bi @(CategoriaId > 0 ? "bi-pencil-square" : "bi-plus-circle")"></i>
                @(CategoriaId > 0 ? "Editar Categoría" : "Nueva Categoría")
            </h4>
        </div>

        <EditForm Model="Categoria" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />

            <div class="card-body">

                <div class="mb-4">
                    <label class="form-label text-muted fw-bold small">NOMBRE</label>
                    <InputText class="form-control input-glass"
                               @bind-Value="Categoria.Nombre"
                               placeholder="Ej: Carnes, Verduras..." />
                    <ValidationMessage For="() => Categoria.Nombre" />
                </div>

            </div>

            <div class="card-footer bg-transparent border-0 d-flex justify-content-between pb-3 px-4">

                <a href="/Logistica/Categorias" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>

                <div class="d-flex gap-2">

                    @if (CategoriaId > 0)
                    {
                        <button type="button"
                                class="btn btn-outline-danger"
                                @onclick="Eliminar">
                            <i class="bi bi-trash"></i>
                        </button>
                    }

                    <button type="submit" class="btn btn-gradiente px-5">
                        <i class="bi bi-check-circle-fill me-2"></i> Guardar
                    </button>

                </div>
            </div>

        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public int CategoriaId { get; set; }

    public Categorias Categoria { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        PageTitleService.SetTitle(CategoriaId > 0 ? "Editar Categoría" : "Crear Categoría");

        if (CategoriaId > 0)
        {
            var encontrada = await categoriaService.Buscar(CategoriaId);

            if (encontrada != null)
            {
                Categoria = encontrada;
            }
            else
            {
                navigationManager.NavigateTo("/Logistica/Categorias");
            }
        }
    }

    public async Task Guardar()
    {
        try
        {
            var guardado = await categoriaService.Guardar(Categoria);

            if (guardado)
            {
                await Swal.FireAsync(new SweetAlertOptions
                {
                    Title = "¡Guardado!",
                    Text = "La categoría se guardó exitosamente.",
                    Icon = SweetAlertIcon.Success
                });

                navigationManager.NavigateTo("/Logistica/Categorias");
            }
        }
        catch (Exception ex)
        {
            await Swal.FireAsync(new SweetAlertOptions
            {
                Title = "Error",
                Text = "Ocurrió un problema al guardar.",
                Icon = SweetAlertIcon.Error
            });
            Console.WriteLine(ex.Message);
        }
    }

    public async Task Eliminar()
    {
        // 1. Alerta de Advertencia Inicial
        var confirmacion = await Swal.FireAsync(new SweetAlertOptions
        {
            Title = "¿Estás seguro?",
            Text = $"¿Deseas eliminar la categoría {Categoria.Nombre}?",
            Icon = SweetAlertIcon.Warning,
            ShowCancelButton = true,
            ConfirmButtonText = "<i class=\"bi bi-trash-fill me-1\"></i> Eliminar",
            CancelButtonText = "<i class=\"bi bi-x-circle-fill me-1\"></i> Cancelar"
        });

        if (!string.IsNullOrEmpty(confirmacion.Value))
        {
            // 2. Pedimos la contraseña
            var passwordResult = await Swal.FireAsync(new SweetAlertOptions
            {
                Title = "Confirmar identidad",
                Text = "Ingresa tu contraseña de administrador para autorizar:",
                Input = SweetAlertInputType.Password,
                InputPlaceholder = "Tu contraseña",
                ShowCancelButton = true,
                ConfirmButtonText = "<i class=\"bi bi-shield-lock-fill me-1\"></i> Verificar",
                CancelButtonText = "<i class=\"bi bi-x-circle-fill me-1\"></i> Cancelar"
            });

            if (!string.IsNullOrEmpty(passwordResult.Value))
            {
                string passwordIngresado = passwordResult.Value;

                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var user = await UserManager.GetUserAsync(authState.User);

                bool passwordCorrecto = false;
                if (user != null)
                {
                    // Validación real con Identity
                    passwordCorrecto = await UserManager.CheckPasswordAsync(user, passwordIngresado);
                }

                if (passwordCorrecto)
                {
                    var ok = await categoriaService.Eliminar(CategoriaId);

                    if (ok)
                    {
                        await Swal.FireAsync(new SweetAlertOptions
                        {
                            Title = "¡Eliminada!",
                            Text = "La categoría se borró correctamente.",
                            Icon = SweetAlertIcon.Success
                        });
                        navigationManager.NavigateTo("/Logistica/Categorias");
                    }
                    else
                    {
                        await Swal.FireAsync(new SweetAlertOptions
                        {
                            Title = "Error",
                            Text = "No se pudo eliminar de la base de datos.",
                            Icon = SweetAlertIcon.Error
                        });
                    }
                }
                else
                {
                    await Swal.FireAsync(new SweetAlertOptions
                    {
                        Title = "Acceso Denegado",
                        Text = "La contraseña es incorrecta. Operación cancelada.",
                        Icon = SweetAlertIcon.Error
                    });
                }
            }
        }
    }
}