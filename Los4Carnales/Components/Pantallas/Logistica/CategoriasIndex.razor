@page "/Logistica/Categorias"

@using Microsoft.AspNetCore.Authorization
@using Los4Carnales.Services
@using Los4Carnales.Models

@inject CategoriaService categoriaService
@inject NavigationManager navigationManager
@inject PageTitleService PageTitleService

@attribute [Authorize(Roles = "Administrador")]

<PageTitle>Categorías</PageTitle>

<div class="container">
    <div class="card card-glass rounded-4 p-3 shadow-lg">

        <div class="card-header bg-transparent border-0 pb-0 d-flex justify-content-between align-items-center mb-3">
            <div>
                <h4 class="fw-bold text-warning">
                    <i class="bi bi-tags-fill"></i> Categorías
                </h4>
                <p class="text-muted small mb-0">
                    Gestione las categorías de los productos.
                </p>
            </div>

            <div class="btn-group">
                <a href="/Logistica/Index" class="btn btn-outline-secondary me-2">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>

                <a href="/Logistica/Categorias/Create" class="btn btn-gradiente">
                    <i class="bi bi-plus-lg"></i> Nueva Categoría
                </a>
            </div>
        </div>

        <div class="card-body">

            @if (Cargando)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-warning"></div>
                </div>
            }
            else if (!ListaCategorias.Any())
            {
                <div class="alert alert-info text-center">
                    No hay categorías registradas.
                </div>
            }
            else
            {
                <div class="table-responsive rounded-3 border">
                    <table class="table table-hover align-middle mb-0">

                        <thead class="bg-light text-secondary">
                            <tr>
                                <th class="ps-4">Nombre</th>
                                <th class="text-center">Opciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in ListaCategorias)
                            {
                                <tr style="border-bottom: 1px solid rgba(0,0,0,0.05);">

                                    <td class="ps-4 fw-bold">
                                        @item.Nombre

                                        @if (item.Eliminado)
                                        {
                                            <span class="badge bg-danger ms-2">Eliminado</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        <a href="/Logistica/Categorias/Edit/@item.CategoriaId"
                                           class="btn btn-sm btn-outline-primary border-0">
                                            <i class="bi bi-pencil-square fs-5"></i>
                                        </a>
                                    </td>

                                </tr>
                            }
                        </tbody>

                    </table>
                </div>
            }
        </div>

        <div class="card-footer bg-transparent border-0 text-muted small ps-4">
            Total Registros: @ListaCategorias.Count
        </div>

    </div>
</div>

@code {
    public List<Categorias> ListaCategorias { get; set; } = new();
    public bool Cargando { get; set; } = true;

    protected override async Task OnInitializedAsync()
    {
        PageTitleService.SetTitle("Categorías");
        await Cargar();
    }

    async Task Cargar()
    {
        Cargando = true;

        // 🔥 SIN filtro Eliminado
        ListaCategorias = await categoriaService.Listar(_ => true);

        Cargando = false;
    }
}