@page "/Logistica/Sectores/Create"
@page "/Logistica/Sectores/Edit/{SectorId:int}"

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Los4Carnales.Data
@using Los4Carnales.Services
@using Los4Carnales.Models

@inject SectorService sectorService
@inject NavigationManager navigationManager
@inject PageTitleService PageTitleService
@inject SweetAlertService Swal
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrador")]

<PageTitle>@(SectorId > 0 ? "Editar" : "Crear") Sector</PageTitle>

<div class="container">
    <div class="card card-glass rounded-4 p-2 shadow-sm mx-auto" style="max-width: 600px;">

        <div class="card-header bg-transparent border-0 text-center pb-0">
            <h4 class="fw-bold text-success">
                <i class="bi @(SectorId > 0 ? "bi-pencil-square" : "bi-plus-circle")"></i>
                @(SectorId > 0 ? "Editar Dirección" : "Nueva Dirección")
            </h4>
        </div>

        <EditForm Model="Sector" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />

            <div class="card-body">

                <div class="mb-4">
                    <label class="form-label text-muted fw-bold small">MUNICIPIO</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-success">
                            <i class="bi bi-geo-alt"></i>
                        </span>
                        <InputSelect class="form-select input-glass border-start-0"
                                     @bind-Value="Sector.Municipio">
                            <option value="" disabled>Seleccione Municipio...</option>
                            <option value="El Factor">El Factor</option>
                            <option value="Nagua">Nagua</option>
                            <option value="Cabrera">Cabrera</option>
                            <option value="Río San Juan">Río San Juan</option>
                        </InputSelect>
                    </div>
                    <ValidationMessage For="() => Sector.Municipio" />
                </div>

                <div class="mb-4">
                    <label class="form-label text-muted fw-bold small">NOMBRE DEL SECTOR / BARRIO</label>
                    <InputText class="form-control input-glass"
                               @bind-Value="Sector.Nombre"
                               placeholder="Ej: Pueblo Nuevo, El Barro..." />
                    <ValidationMessage For="() => Sector.Nombre" />
                </div>

            </div>

            <div class="card-footer bg-transparent border-0 d-flex justify-content-between pb-3 px-4">

                <a href="/Logistica/Sectores" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>

                <div class="d-flex gap-2">

                    @* Botón eliminar SOLO en edición *@
                    @if (SectorId > 0)
                    {
                        <button type="button" class="btn btn-outline-danger"
                                @onclick="Eliminar">
                            <i class="bi bi-trash"></i>
                        </button>
                    }

                    <button type="submit" class="btn btn-gradiente px-5 shadow-sm">
                        <i class="bi bi-check-circle-fill me-2"></i> Guardar
                    </button>

                </div>
            </div>

        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public int SectorId { get; set; }

    public Sector Sector { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        PageTitleService.SetTitle(SectorId > 0 ? "Editar Sector" : "Crear Sector");

        if (SectorId > 0)
        {
            var encontrado = await sectorService.Buscar(SectorId);

            if (encontrado != null)
            {
                Sector = encontrado;
            }
            else
            {
                navigationManager.NavigateTo("/Logistica/Sectores");
            }
        }
    }

    public async Task Guardar()
    {
        try
        {
            var guardado = await sectorService.Guardar(Sector);

            if (guardado)
            {
                await Swal.FireAsync(new SweetAlertOptions
                {
                    Title = "¡Guardado!",
                    Text = "El sector se guardó exitosamente.",
                    Icon = SweetAlertIcon.Success
                });

                navigationManager.NavigateTo("/Logistica/Sectores");
            }
        }
        catch (Exception ex)
        {
            await Swal.FireAsync(new SweetAlertOptions
            {
                Title = "Error",
                Text = "Ocurrió un problema al guardar.",
                Icon = SweetAlertIcon.Error
            });
            Console.WriteLine(ex.Message);
        }
    }

    public async Task Eliminar()
    {
        // 1. Alerta de Advertencia Inicial
        var confirmacion = await Swal.FireAsync(new SweetAlertOptions
        {
            Title = "¿Estás seguro?",
            Text = $"¿Deseas eliminar el sector {Sector.Nombre}?",
            Icon = SweetAlertIcon.Warning,
            ShowCancelButton = true,
            ConfirmButtonText = "<i class=\"bi bi-trash-fill me-1\"></i> Eliminar",
            CancelButtonText = "<i class=\"bi bi-x-circle-fill me-1\"></i> Cancelar"
        });

        if (!string.IsNullOrEmpty(confirmacion.Value))
        {
            // 2. Pedimos la contraseña
            var passwordResult = await Swal.FireAsync(new SweetAlertOptions
            {
                Title = "Confirmar identidad",
                Text = "Ingresa tu contraseña de administrador para autorizar:",
                Input = SweetAlertInputType.Password,
                InputPlaceholder = "Tu contraseña",
                ShowCancelButton = true,
                ConfirmButtonText = "<i class=\"bi bi-shield-lock-fill me-1\"></i> Verificar",
                CancelButtonText = "<i class=\"bi bi-x-circle-fill me-1\"></i> Cancelar"
            });

            if (!string.IsNullOrEmpty(passwordResult.Value))
            {
                string passwordIngresado = passwordResult.Value;

                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var user = await UserManager.GetUserAsync(authState.User);

                bool passwordCorrecto = false;
                if (user != null)
                {
                    // Validación real con Identity
                    passwordCorrecto = await UserManager.CheckPasswordAsync(user, passwordIngresado);
                }

                if (passwordCorrecto)
                {
                    var ok = await sectorService.Eliminar(SectorId);

                    if (ok)
                    {
                        await Swal.FireAsync(new SweetAlertOptions
                        {
                            Title = "¡Eliminado!",
                            Text = "El sector se borró correctamente.",
                            Icon = SweetAlertIcon.Success
                        });
                        navigationManager.NavigateTo("/Logistica/Sectores");
                    }
                    else
                    {
                        await Swal.FireAsync(new SweetAlertOptions
                        {
                            Title = "Error",
                            Text = "No se pudo eliminar de la base de datos.",
                            Icon = SweetAlertIcon.Error
                        });
                    }
                }
                else
                {
                    await Swal.FireAsync(new SweetAlertOptions
                    {
                        Title = "Acceso Denegado",
                        Text = "La contraseña es incorrecta. Operación cancelada.",
                        Icon = SweetAlertIcon.Error
                    });
                }
            }
        }
    }
}