@page "/Logistica/Index"

@using Los4Carnales.Services
@using Microsoft.AspNetCore.Authorization

@inject SectorService sectorService
@inject UnidadMedidaService unidadService
@inject CategoriaService categoriaService
@inject NavigationManager navigationManager
@inject PageTitleService PageTitleService

@attribute [Authorize(Roles = "Administrador")]

<PageTitle>Panel de Logística</PageTitle>

<div class="container">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold text-dark"><i class="bi bi-truck-front"></i> Panel de Logística</h2>
            <p class="text-muted">Gestión general de sectores de entrega y unidades de medida.</p>
        </div>
    </div>

    <div class="row g-4">

        @* Sectores *@
        <div class="col-md-4">
            <div class="card card-glass h-100 shadow-sm border-0">
                <div class="card-body d-flex flex-column align-items-center text-center p-5">
                    <div class="bg-success bg-opacity-10 p-4 rounded-circle mb-3">
                        <i class="bi bi-geo-alt-fill text-success fs-1"></i>
                    </div>
                    <h3 class="fw-bold">Sectores</h3>
                    <p class="text-muted">Gestione los barrios y rutas de entrega.</p>

                    <h2 class="fw-bold text-success my-3">@CantidadSectores</h2>

                    <a href="/Logistica/Sectores" class="btn btn-outline-success rounded-pill mt-auto">
                        Ver <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        @* Unidades *@
        <div class="col-md-4">
            <div class="card card-glass h-100 shadow-sm border-0">
                <div class="card-body d-flex flex-column align-items-center text-center p-5">
                    <div class="bg-primary bg-opacity-10 p-4 rounded-circle mb-3">
                        <i class="bi bi-rulers text-primary fs-1"></i>
                    </div>
                    <h3 class="fw-bold">Unidades</h3>
                    <p class="text-muted">Configure medidas y abreviaturas.</p>

                    <h2 class="fw-bold text-primary my-3">@CantidadUnidades</h2>

                    <a href="/Logistica/Unidades" class="btn btn-outline-primary rounded-pill mt-auto">
                        Ver <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        @* Categorías *@
        <div class="col-md-4">
            <div class="card card-glass h-100 shadow-sm border-0">
                <div class="card-body d-flex flex-column align-items-center text-center p-5">
                    <div class="bg-warning bg-opacity-10 p-4 rounded-circle mb-3">
                        <i class="bi bi-tags-fill text-warning fs-1"></i>
                    </div>
                    <h3 class="fw-bold">Categorías</h3>
                    <p class="text-muted">Organiza los productos.</p>

                    <h2 class="fw-bold text-warning my-3">@CantidadCategorias</h2>

                    <a href="/Logistica/Categorias" class="btn btn-outline-warning rounded-pill mt-auto">
                        Ver <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>

@code {
    public int CantidadSectores { get; set; }
    public int CantidadUnidades { get; set; }
    public int CantidadCategorias { get; set; }

    protected override async Task OnInitializedAsync()
    {
        PageTitleService.SetTitle("Logística");

        CantidadSectores = (await sectorService.Listar(s => !s.Eliminado)).Count;
        CantidadUnidades = (await unidadService.Listar(u => !u.Eliminado)).Count;
        CantidadCategorias = (await categoriaService.Listar(c => !c.Eliminado)).Count;
    }
}